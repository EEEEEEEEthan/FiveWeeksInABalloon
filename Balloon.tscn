[sub_resource type="GDScript" id="GDScript_gxany"]
resource_name = "Balloon"
script/source = "extends Node3D

@export_range(0.0, 5.0, 0.01) var max_drift_range: float = 0.35

var _time := 0.0
var _phase := 0.0


func _ready() -> void:
	_phase = float(get_instance_id() % 1024) * 0.013


func _process(delta: float) -> void:
	_time += delta
	var t := _time * 0.6 + _phase
	var offset := Vector3(
		sin(t * 0.83) * 0.55 + sin(t * 1.71) * 0.2,
		sin(t * 1.11) * 0.65 + cos(t * 0.37) * 0.15,
		cos(t * 0.74) * 0.45 + sin(t * 1.29) * 0.18
	)
	if offset.length() > 0.0:
		offset = offset.normalized() * min(offset.length(), 1.0)
	position = offset * max_drift_range
"


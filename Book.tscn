[sub_resource type="Shader" id="Shader_d1o3a"]
code = "shader_type spatial;

uniform sampler2D viewport_tex;

void vertex() {
}

void fragment() {
	// 用书页 UV 采样 SubViewport 渲染的 sky，V 需翻转与视口一致
	vec2 uv = vec2(UV.x, 1.0 - UV.y);
	ALBEDO = texture(viewport_tex, uv).rgb;
}
"

